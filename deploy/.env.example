# =============================================================================
# RayNet MinIO Configuration
# Copy to .env and edit before running: docker compose up -d
# =============================================================================

# MinIO root credentials (change in production!)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme-strong-password-here

# Default bucket for GazeGene MDS shards
MINIO_BUCKET=gazegene

# Port mapping
MINIO_API_PORT=9000      # S3 API endpoint
MINIO_CONSOLE_PORT=9001  # Web UI (http://localhost:9001)
